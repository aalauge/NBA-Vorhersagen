<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.kobra.updatestats</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/artem/kobra-nba/update_stats.sh</string>
    </array>

    <!-- Jeden Tag um 09:00 Uhr Ortszeit -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>9</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <!-- Verpasste Ausführung nachholen wenn Mac aus war -->
    <key>StartInterval</key>
    <integer>86400</integer>

    <key>StandardOutPath</key>
    <string>/tmp/kobra-update.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/kobra-update-error.log</string>
</dict>
</plist>
